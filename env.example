# Copy this file to .env and fill in your values.
# Never commit .env to Git.

DJANGO_SECRET_KEY=your-very-secret-key-replace-this
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL — match your local Postgres setup
DATABASE_URL=postgres://postgres:yourpassword@localhost:5432/maternal_referral

# JWT token lifetimes
ACCESS_TOKEN_LIFETIME_MINUTES=15
REFRESH_TOKEN_LIFETIME_DAYS=7

# CORS — add your frontend URL here when you have one
CORS_ALLOWED_ORIGINS=http://localhost:3000
